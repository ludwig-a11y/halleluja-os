        []
      ]
    },
    "Split GF IDs": {
      "main": [
        [{ "node": "Slack: Blocker DM", "type": "main", "index": 0 }]
      ]
    },
    "Big 3 erledigt?": {
      "main": [
        [{ "node": "Slack: Big 3 Channel", "type": "main", "index": 0 }],
        []
      ]
    },
    "Meilenstein?": {
      "main": [
        [{ "node": "Slack: Meilenstein Channel", "type": "main", "index": 0 }],
        []
      ]
    }
  },
  "settings": {
